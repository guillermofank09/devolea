# Google Analytics 4 — Measurement ID (formato: G-XXXXXXXXXX)
# Obtenerlo en: https://analytics.google.com → Admin → Data Streams → tu stream → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Número de WhatsApp para el botón "Prueba Devolea" (formato internacional sin + ni espacios, ej: 5491112345678)
VITE_CONTACT_PHONE=

# Google Maps — habilitar: Maps JavaScript API, Places API, Geocoding API
# Obtenerlo en: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=
# Map ID (opcional, para estilos de mapa personalizados). "DEMO_MAP_ID" para desarrollo.
# Crear en: https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
